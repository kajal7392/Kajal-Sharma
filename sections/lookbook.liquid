{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ============================================================
     LOOKBOOK GALLERY STYLES
     ============================================================ */
  .lookbook-{{ section.id }} {
    max-width: 1240px;
    margin: 0 auto;
    font-family: 'Lustria', serif;
    padding-left: 20px;
    padding-right: 20px;
  }

  /* ============================================================
     SECTION HEADER - Desktop: Left aligned with proper spacing
     ============================================================ */
  .lookbook-{{ section.id }} .section-header {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 30px;
    padding: 0;
    max-width: 1339px;
    margin-left: auto;
    margin-right: auto;
  }

  .lookbook-{{ section.id }} .section-title {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    color: {{ section.settings.title_color | default: '#000000' }};
    margin: 0;
    padding: 0;
    letter-spacing: 0;
    text-transform: none;
  }

  /* ============================================================
     DESKTOP GRID - 3 columns, 20px gap, centered with max-width
     ============================================================ */
  .lookbook-{{ section.id }} .lookbook-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1339px;
    margin: 0 auto;
  }

  /* ============================================================
     IMAGE CARD - With 1.5px black border
     ============================================================ */
  .lookbook-{{ section.id }} .lookbook-card {
    position: relative;
    overflow: hidden;
    width: 100%;
    background: #f5f5f5;
    border: 1.5px solid {{ section.settings.border_color | default: '#000000' }};
    aspect-ratio: auto;
  }

  .lookbook-{{ section.id }} .lookbook-card .media {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .lookbook-{{ section.id }} .lookbook-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lookbook-{{ section.id }} .lookbook-card:hover img {
    transform: scale(1.03);
  }

  /* ============================================================
     HOTSPOT STYLES - With Ripple/Blinking Animation
     ============================================================ */
  .lookbook-{{ section.id }} hotspot-button {
    position: absolute;
    top: var(--offset-y);
    left: var(--offset-x);
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .lookbook-{{ section.id }} .hotspot-btn {
    width: {{ section.settings.hotspot_size | default: 32 }}px;
    height: {{ section.settings.hotspot_size | default: 32 }}px;
    border-radius: 50%;
    background: {{ section.settings.hotspot_bg | default: '#FFFFFF' }};
    color: {{ section.settings.hotspot_color | default: '#000000' }};
    border: 2px solid rgba(255, 255, 255, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.15);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    text-decoration: none;
  }

  /* ============================================================
     RIPPLE/BLINKING ANIMATION
     ============================================================ */
  .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::before,
  .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid {{ section.settings.hotspot_bg | default: '#FFFFFF' }};
    opacity: 0;
    animation: hotspot-ripple-{{ section.id }} 2s ease-out infinite;
  }

  .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after {
    animation-delay: 1s;
  }

  @keyframes hotspot-ripple-{{ section.id }} {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }

  /* ============================================================
     HOTSPOT ICON
     ============================================================ */
  .lookbook-{{ section.id }} .hotspot-btn .material-icon {
    width: {{ section.settings.hotspot_icon_size | default: 20 }}px;
    height: {{ section.settings.hotspot_icon_size | default: 20 }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lookbook-{{ section.id }} .hotspot-btn .material-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ============================================================
     HOTSPOT HOVER EFFECTS
     ============================================================ */
  .lookbook-{{ section.id }} .hotspot-btn:hover {
    background: {{ section.settings.hotspot_hover_bg | default: '#000000' }};
    color: {{ section.settings.hotspot_hover_color | default: '#FFFFFF' }};
    transform: scale(1.15);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .lookbook-{{ section.id }} .hotspot-btn:hover .material-icon {
    transform: rotate(90deg);
  }

  /* ============================================================
     HOTSPOT TOOLTIP
     ============================================================ */
  .lookbook-{{ section.id }} .hotspot-btn .hotspot-label {
    display: none;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 12px;
    white-space: nowrap;
    font-family: 'Lustria', serif;
    font-weight: 400;
    pointer-events: none;
    letter-spacing: 0.02em;
  }

  .lookbook-{{ section.id }} .hotspot-btn:hover .hotspot-label {
    display: block;
  }

  /* ============================================================
     RESPONSIVE - TABLET
     ============================================================ */
  @media screen and (max-width: 1024px) {
    .lookbook-{{ section.id }} {
      padding-left: 20px;
      padding-right: 20px;
    }

    .lookbook-{{ section.id }} .lookbook-grid {
      gap: 16px;
    }

    .lookbook-{{ section.id }} .section-title {
      font-size: 30px;
    }
  }

  /* ============================================================
     RESPONSIVE - MOBILE (max-width: 749px)
     - 2 columns grid
     - Smaller title (responsive)
     - 4px gap between images
     - 1px border
     - No padding issues
     ============================================================ */
  @media screen and (max-width: 749px) {
    .lookbook-{{ section.id }} {
      padding-left: 0;
      padding-right: 0;
    }

    .lookbook-{{ section.id }} .section-header {
      justify-content: center;
      padding: 0 16px;
      margin-bottom: 20px;
      max-width: 100%;
    }

    .lookbook-{{ section.id }} .section-title {
      font-size: 24px;
      text-align: center;
      max-width: 100%;
    }

    /* Mobile grid: 2 columns with 4px gap */
    .lookbook-{{ section.id }} .lookbook-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
      padding: 0 16px;
      max-width: 100%;
      margin: 0;
    }

    .lookbook-{{ section.id }} .lookbook-card {
      border-width: 1px;
      aspect-ratio: auto;
    }

    .lookbook-{{ section.id }} .lookbook-card .media {
      aspect-ratio: auto;
    }

    .lookbook-{{ section.id }} .lookbook-card img {
      aspect-ratio: auto;
    }

    .lookbook-{{ section.id }} .hotspot-btn {
      width: {{ section.settings.hotspot_size_mobile | default: 28 }}px;
      height: {{ section.settings.hotspot_size_mobile | default: 28 }}px;
    }

    .lookbook-{{ section.id }} .hotspot-btn .material-icon {
      width: {{ section.settings.hotspot_icon_size_mobile | default: 16 }}px;
      height: {{ section.settings.hotspot_icon_size_mobile | default: 16 }}px;
    }

    .lookbook-{{ section.id }} hotspot-button {
      top: var(--mobile-offset-y, var(--offset-y));
      left: var(--mobile-offset-x, var(--offset-x));
    }

    .lookbook-{{ section.id }} .hotspot-btn .hotspot-label {
      font-size: 10px;
      padding: 4px 10px;
      bottom: calc(100% + 8px);
    }

    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::before,
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after {
      inset: -3px;
    }

    @keyframes hotspot-ripple-{{ section.id }} {
      0% {
        transform: scale(1);
        opacity: 0.6;
      }
      100% {
        transform: scale(1.4);
        opacity: 0;
      }
    }
  }

  /* ============================================================
     RESPONSIVE - SMALL MOBILE (max-width: 480px)
     ============================================================ */
  @media screen and (max-width: 480px) {
    .lookbook-{{ section.id }} .section-title {
      font-size: 20px;
    }

    .lookbook-{{ section.id }} .lookbook-grid {
      gap: 4px;
      padding: 0 12px;
    }

    .lookbook-{{ section.id }} .hotspot-btn {
      width: 24px;
      height: 24px;
    }

    .lookbook-{{ section.id }} .hotspot-btn .material-icon {
      width: 14px;
      height: 14px;
    }
  }

  /* ============================================================
     REDUCED MOTION
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .lookbook-{{ section.id }} .lookbook-card img {
      transition: none;
    }
    .lookbook-{{ section.id }} .hotspot-btn {
      transition: none;
    }
    .lookbook-{{ section.id }} .hotspot-btn:hover {
      transform: none;
    }
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::before,
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after {
      animation: none;
    }
    .lookbook-{{ section.id }} .hotspot-btn:hover .material-icon {
      transform: none;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding lookbook-{{ section.id }}">
  
  <!-- ============================================================
       SECTION HEADER
       Desktop: Left aligned with proper spacing
       Mobile: Center aligned
       ============================================================ -->
  <div class="section-header">
    <h2 class="section-title">
      {{ section.settings.section_title | default: 'Tisso vison in the wild' }}
    </h2>
  </div>

  <!-- ============================================================
       GALLERY GRID
       Desktop: 3 columns, 20px gap, centered
       Mobile: 2 columns, 4px gap
       ============================================================ -->
  <div class="lookbook-grid">
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'image' -%}
          
          {%- liquid
            assign image = block.settings.image
            assign image_alt = block.settings.image_alt | default: image.alt | default: 'Gallery image'
            
            # Hotspot 1 settings
            assign hs1_enable = block.settings.hotspot_1_enable
            assign hs1_link = block.settings.hotspot_1_link
            assign hs1_top = block.settings.hotspot_1_top | default: 50
            assign hs1_left = block.settings.hotspot_1_left | default: 50
            assign hs1_label = block.settings.hotspot_1_label
            assign hs1_mobile_top = block.settings.hotspot_1_mobile_top | default: hs1_top
            assign hs1_mobile_left = block.settings.hotspot_1_mobile_left | default: hs1_left
            
            # Hotspot 2 settings
            assign hs2_enable = block.settings.hotspot_2_enable
            assign hs2_link = block.settings.hotspot_2_link
            assign hs2_top = block.settings.hotspot_2_top | default: 50
            assign hs2_left = block.settings.hotspot_2_left | default: 50
            assign hs2_label = block.settings.hotspot_2_label
            assign hs2_mobile_top = block.settings.hotspot_2_mobile_top | default: hs2_top
            assign hs2_mobile_left = block.settings.hotspot_2_mobile_left | default: hs2_left
            
            # Hotspot 3 settings
            assign hs3_enable = block.settings.hotspot_3_enable
            assign hs3_link = block.settings.hotspot_3_link
            assign hs3_top = block.settings.hotspot_3_top | default: 50
            assign hs3_left = block.settings.hotspot_3_left | default: 50
            assign hs3_label = block.settings.hotspot_3_label
            assign hs3_mobile_top = block.settings.hotspot_3_mobile_top | default: hs3_top
            assign hs3_mobile_left = block.settings.hotspot_3_mobile_left | default: hs3_left
            
            # Hotspot 4 settings
            assign hs4_enable = block.settings.hotspot_4_enable
            assign hs4_link = block.settings.hotspot_4_link
            assign hs4_top = block.settings.hotspot_4_top | default: 50
            assign hs4_left = block.settings.hotspot_4_left | default: 50
            assign hs4_label = block.settings.hotspot_4_label
            assign hs4_mobile_top = block.settings.hotspot_4_mobile_top | default: hs4_top
            assign hs4_mobile_left = block.settings.hotspot_4_mobile_left | default: hs4_left
            
            # Ripple animation setting
            assign enable_ripple = section.settings.enable_ripple_animation | default: true
            assign ripple_class = ''
            if enable_ripple
              assign ripple_class = 'ripple-animation'
            endif
          -%}
          
          <div 
            class="lookbook-card" 
            {{ block.shopify_attributes }}
            data-block-type="image"
          >
            {%- if image != blank -%}
              <div class="media">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  srcset="
                    {{ image | image_url: width: 400 }} 400w,
                    {{ image | image_url: width: 600 }} 600w,
                    {{ image | image_url: width: 800 }} 800w,
                    {{ image | image_url: width: 1000 }} 1000w
                  "
                  sizes="(max-width: 749px) calc(50vw - 20px), (max-width: 1024px) calc(33vw - 30px), calc(33vw - 40px)"
                  alt="{{ image_alt | escape }}"
                  loading="lazy"
                >
              </div>
            {%- else -%}
              <div style="width:100%;height:100%;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#999;font-size:14px;padding:20px;text-align:center;aspect-ratio:1/1;">
                {{ 'onboarding.no_image' | t }}
                <br>
                <small>Add image in Theme Editor</small>
              </div>
            {%- endif -%}
            
            <!-- ============================================================
                 HOTSPOT 1
                 ============================================================ -->
            {%- if hs1_enable and hs1_link != blank -%}
              <hotspot-button
                class="hotspot"
                data-type="link"
                data-open-event="click"
                data-open="false"
                data-section="{{ section.id }}"
                style="--offset-x:{{ hs1_left }}%;--offset-y:{{ hs1_top }}%;--mobile-offset-x:{{ hs1_mobile_left }}%;--mobile-offset-y:{{ hs1_mobile_top }}%;"
              >
                <a
                  href="{{ hs1_link }}"
                  class="hotspot-btn {{ ripple_class }}"
                  aria-label="{{ hs1_label | default: 'View product' | escape }}"
                >
                  {% render 'material-icon', icon: 'add' %}
                  {%- if hs1_label != blank -%}
                    <span class="hotspot-label">{{ hs1_label }}</span>
                  {%- endif -%}
                </a>
              </hotspot-button>
            {%- endif -%}
            
            <!-- ============================================================
                 HOTSPOT 2
                 ============================================================ -->
            {%- if hs2_enable and hs2_link != blank -%}
              <hotspot-button
                class="hotspot"
                data-type="link"
                data-open-event="click"
                data-open="false"
                data-section="{{ section.id }}"
                style="--offset-x:{{ hs2_left }}%;--offset-y:{{ hs2_top }}%;--mobile-offset-x:{{ hs2_mobile_left }}%;--mobile-offset-y:{{ hs2_mobile_top }}%;"
              >
                <a
                  href="{{ hs2_link }}"
                  class="hotspot-btn {{ ripple_class }}"
                  aria-label="{{ hs2_label | default: 'View product' | escape }}"
                >
                  {% render 'material-icon', icon: 'add' %}
                  {%- if hs2_label != blank -%}
                    <span class="hotspot-label">{{ hs2_label }}</span>
                  {%- endif -%}
                </a>
              </hotspot-button>
            {%- endif -%}
            
            <!-- ============================================================
                 HOTSPOT 3
                 ============================================================ -->
            {%- if hs3_enable and hs3_link != blank -%}
              <hotspot-button
                class="hotspot"
                data-type="link"
                data-open-event="click"
                data-open="false"
                data-section="{{ section.id }}"
                style="--offset-x:{{ hs3_left }}%;--offset-y:{{ hs3_top }}%;--mobile-offset-x:{{ hs3_mobile_left }}%;--mobile-offset-y:{{ hs3_mobile_top }}%;"
              >
                <a
                  href="{{ hs3_link }}"
                  class="hotspot-btn {{ ripple_class }}"
                  aria-label="{{ hs3_label | default: 'View product' | escape }}"
                >
                  {% render 'material-icon', icon: 'add' %}
                  {%- if hs3_label != blank -%}
                    <span class="hotspot-label">{{ hs3_label }}</span>
                  {%- endif -%}
                </a>
              </hotspot-button>
            {%- endif -%}
            
            <!-- ============================================================
                 HOTSPOT 4
                 ============================================================ -->
            {%- if hs4_enable and hs4_link != blank -%}
              <hotspot-button
                class="hotspot"
                data-type="link"
                data-open-event="click"
                data-open="false"
                data-section="{{ section.id }}"
                style="--offset-x:{{ hs4_left }}%;--offset-y:{{ hs4_top }}%;--mobile-offset-x:{{ hs4_mobile_left }}%;--mobile-offset-y:{{ hs4_mobile_top }}%;"
              >
                <a
                  href="{{ hs4_link }}"
                  class="hotspot-btn {{ ripple_class }}"
                  aria-label="{{ hs4_label | default: 'View product' | escape }}"
                >
                  {% render 'material-icon', icon: 'add' %}
                  {%- if hs4_label != blank -%}
                    <span class="hotspot-label">{{ hs4_label }}</span>
                  {%- endif -%}
                </a>
              </hotspot-button>
            {%- endif -%}
            
          </div>
          
      {%- endcase -%}
    {%- endfor -%}
    
  </div>
</div>

<!-- ============================================================
     JAVASCRIPT - Vanilla JS (No jQuery)
     ============================================================ -->
<script>
  (function() {
    'use strict';
    
    /**
     * LookbookGallery - Handles hotspot interactions
     */
    class LookbookGallery {
      constructor(section) {
        this.section = section;
        this.hotspots = section.querySelectorAll('hotspot-button');
        this.init();
      }
      
      init() {
        this.hotspots.forEach(hotspot => {
          const btn = hotspot.querySelector('.hotspot-btn');
          if (!btn) return;
          
          // Handle click events for toggling
          btn.addEventListener('click', function(e) {
            const isOpen = hotspot.dataset.open === 'true';
            hotspot.dataset.open = isOpen ? 'false' : 'true';
          });
          
          // Keyboard accessibility
          btn.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              const isOpen = hotspot.dataset.open === 'true';
              hotspot.dataset.open = isOpen ? 'false' : 'true';
            }
          });
        });
        
        // Close hotspots when clicking outside
        document.addEventListener('click', function(e) {
          if (!e.target.closest('hotspot-button')) {
            document.querySelectorAll('hotspot-button').forEach(function(h) {
              h.dataset.open = 'false';
            });
          }
        });
        
        // Log in Theme Editor
        if (window.Shopify && Shopify.designMode) {
          console.log('[LookbookGallery] Initialized with', this.hotspots.length, 'hotspots');
        }
      }
    }
    
    function initLookbook() {
      var sections = document.querySelectorAll('[data-section-type="lookbook-gallery"]');
      sections.forEach(function(section) {
        if (section._lookbookInstance) return;
        section._lookbookInstance = new LookbookGallery(section);
      });
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLookbook);
    } else {
      initLookbook();
    }
    
    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', initLookbook);
      document.addEventListener('shopify:section:reorder', initLookbook);
    }
    
  })();
</script>

{% schema %}
{
  "name": "Lookbook Gallery",
  "tag": "section",
  "class": "section-lookbook",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Tisso vison in the wild",
      "info": "Note: The design uses 'vison' (typo preserved from Figma)"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Image Border Color",
      "default": "#000000",
      "info": "1.5px border around each image (Figma spec)"
    },
    {
      "type": "color",
      "id": "hotspot_bg",
      "label": "Hotspot Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "hotspot_color",
      "label": "Hotspot Icon Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "hotspot_hover_bg",
      "label": "Hotspot Hover Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "hotspot_hover_color",
      "label": "Hotspot Hover Icon Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Hotspot Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_ripple_animation",
      "label": "Enable Ripple/Blinking Animation",
      "default": true,
      "info": "Creates a pulsing ring effect around hotspots"
    },
    {
      "type": "range",
      "id": "hotspot_size",
      "label": "Hotspot Size - Desktop (px)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hotspot_size_mobile",
      "label": "Hotspot Size - Mobile (px)",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hotspot_icon_size",
      "label": "Icon Size - Desktop (px)",
      "min": 12,
      "max": 28,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hotspot_icon_size_mobile",
      "label": "Icon Size - Mobile (px)",
      "min": 10,
      "max": 20,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "checkbox",
