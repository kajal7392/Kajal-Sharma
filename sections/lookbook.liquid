{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lookbook-{{ section.id }} {
    max-width: 1440px;
    margin: 0 auto;
    font-family: 'Lustria', serif;
    padding-left: 20px;
    padding-right: 20px;
  }

  .lookbook-{{ section.id }} .section-header {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 30px;
    padding: 0;
    max-width: 1339px;
    margin-left: auto;
    margin-right: auto;
  }

  .lookbook-{{ section.id }} .section-title {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    color: {{ section.settings.title_color | default: '#000000' }};
    margin: 0;
    padding: 0;
    letter-spacing: 0;
    text-transform: none;
  }

  .lookbook-{{ section.id }} .lookbook-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1339px;
    margin: 0 auto;
  }

  .lookbook-{{ section.id }} .lookbook-card {
    position: relative;
    overflow: hidden;
    width: 100%;
    background: #f5f5f5;
    border: 1.5px solid {{ section.settings.border_color | default: '#000000' }};
    aspect-ratio: auto;
  }

  .lookbook-{{ section.id }} .lookbook-card .media {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .lookbook-{{ section.id }} .lookbook-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lookbook-{{ section.id }} .lookbook-card:hover img {
    transform: scale(1.03);
  }

  .lookbook-{{ section.id }} .hotspot-btn {
    position: absolute;
    z-index: 2;
    width: {{ section.settings.hotspot_size | default: 32 }}px;
    height: {{ section.settings.hotspot_size | default: 32 }}px;
    border-radius: 50%;
    background: {{ section.settings.hotspot_bg | default: '#FFFFFF' }};
    color: {{ section.settings.hotspot_color | default: '#000000' }};
    border: 2px solid rgba(255, 255, 255, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.15);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    transform: translate(-50%, -50%);
  }

  .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::before,
  .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid {{ section.settings.hotspot_bg | default: '#FFFFFF' }};
    opacity: 0;
    animation: hotspot-ripple-{{ section.id }} 2s ease-out infinite;
  }

  .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after {
    animation-delay: 1s;
  }

  @keyframes hotspot-ripple-{{ section.id }} {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  .lookbook-{{ section.id }} .hotspot-btn .material-icon {
    width: {{ section.settings.hotspot_icon_size | default: 20 }}px;
    height: {{ section.settings.hotspot_icon_size | default: 20 }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lookbook-{{ section.id }} .hotspot-btn .material-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .lookbook-{{ section.id }} .hotspot-btn:hover {
    background: {{ section.settings.hotspot_hover_bg | default: '#000000' }};
    color: {{ section.settings.hotspot_hover_color | default: '#FFFFFF' }};
    transform: translate(-50%, -50%) scale(1.15);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .lookbook-{{ section.id }} .hotspot-btn:hover .material-icon {
    transform: rotate(90deg);
  }

  .lookbook-{{ section.id }} .hotspot-btn .hotspot-label {
    display: none;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 12px;
    white-space: nowrap;
    font-family: 'Lustria', serif;
    font-weight: 400;
    pointer-events: none;
    letter-spacing: 0.02em;
  }

  .lookbook-{{ section.id }} .hotspot-btn:hover .hotspot-label {
    display: block;
  }

  .lookbook-popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.5);
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .lookbook-popup-overlay.active {
    display: flex;
    opacity: 1;
  }

  .lookbook-popup-overlay .popup-wrapper {
    position: relative;
    width: 400px;
    height: auto;
    min-height: 447px;
    max-height: 90vh;
    background: #FFFFFF;
    box-shadow: 0px 2px 4px 0px #00000033;
    border-radius: 0;
    overflow: hidden;
    animation: popup-slide-up 0.3s ease;
    flex-shrink: 0;
  }

  @keyframes popup-slide-up {
    from { transform: translateY(20px) scale(0.98); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  .lookbook-popup-overlay .popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 24px;
    height: 24px;
    border: none;
    background: transparent;
    color: #000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: transform 0.3s ease;
  }

  .lookbook-popup-overlay .popup-close:hover {
    transform: rotate(90deg);
  }

  .lookbook-popup-overlay .popup-close svg {
    width: 14px;
    height: 14px;
  }

  .lookbook-popup-overlay .popup-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 36px 17px 20px 17px;
    box-sizing: border-box;
    overflow-y: auto;
    max-height: 90vh;
  }

  .lookbook-popup-overlay .popup-top {
    display: flex;
    gap: 8px;
    height: 140px;
    margin-bottom: 0;
  }

  .lookbook-popup-overlay .popup-image-wrapper {
    flex-shrink: 0;
    width: 120px;
    height: 140px;
    order: 1;
  }

  .lookbook-popup-overlay .popup-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lookbook-popup-overlay .popup-info-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 13px;
    min-width: 0;
    order: 2;
  }

  .lookbook-popup-overlay .popup-title {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 16px;
        color: #000000;
    margin: 0 0 8px 0;
    letter-spacing: 0px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lookbook-popup-overlay .popup-price {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%;
    color: #000000;
    margin: 0 0 10px 0;
    letter-spacing: 0px;
  }

  .lookbook-popup-overlay .popup-description {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: 0;
    color: #000000;
    margin: 0;
    overflow: visible;
    max-height: none;
    word-wrap: break-word;
  }

  .lookbook-popup-overlay .popup-variant-picker {
    margin-top: 6px;
    width: 100%;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-picker {
    width: 100%;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option {
    margin-bottom: 8px;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option legend {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 130%;
    color: #333333;
    display: block;
    margin-bottom: 4px;
    letter-spacing: 0%;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option legend .variant-option__swatch-value {
    font-weight: 400;
    margin-left: 4px;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px !important;
    border: 2px solid #ededed !important;
    font-weight: 600;
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    color: #1a1a1a;
    cursor: pointer;
    transition: all 0.3s ease;
    background: #ffffff;
    margin-right: 4px;
    margin-bottom: 4px;
    min-height: 36px;
    flex: 1 1 auto;
    min-width: 50px;
  }

  .lookbook-popup-overlay .popup-variant-picker .theme-native-inputs-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    width: 100%;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label:has(.swatch) {
    flex: 1 1 auto;
    min-width: 40px;
    max-width: 100%;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label input[type="radio"] {
    display: none;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label:has(input[type="radio"]:checked) {
    border-color: #000000 !important;
    background: #000000 !important;
    color: #ffffff !important;
  }

  .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label:hover {
    border-color: #000000 !important;
  }

  .lookbook-popup-overlay .popup-variant-picker .custom-dropdown-container {
    position: relative;
    display: inline-block;
    width: 100%;
    margin-top: 4px;
  }

  .lookbook-popup-overlay .popup-variant-picker .ui-custom-size-select {
    width: 100%;
    padding: 12px 40px 12px 16px;
    font-size: 15px;
    font-weight: 500;
    color: #1a1a1a;
    background-color: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 0px;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    transition: border-color 0.2s ease-in-out;
    font-family: 'Jost', sans-serif;
  }

  .lookbook-popup-overlay .popup-variant-picker .ui-custom-size-select:focus {
    outline: none;
    border-color: #000000;
  }

  .lookbook-popup-overlay .popup-variant-picker .custom-dropdown-container::after {
    content: " ";
    display: block;
    position: absolute;
    right: 18px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-right: 2px solid #555555;
    border-bottom: 2px solid #555555;
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  .lookbook-popup-overlay .popup-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
    width: 100%;
  }

  .lookbook-popup-overlay .popup-add-to-cart {
    width: 100%;
    height: 45px;
    background: #000000;
    color: #FFFFFF;
    border: none;
    border-radius: 0;
    cursor: pointer;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 0 20px;
    position: relative;
  }

  .lookbook-popup-overlay .popup-add-to-cart:hover:not(:disabled) {
    background: #333333;
    transform: translateY(-1px);
  }

  .lookbook-popup-overlay .popup-add-to-cart:disabled {
    background: #999999;
    cursor: not-allowed;
  }

  .lookbook-popup-overlay .popup-add-to-cart .cart-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    width: 24px;
    height: 24px;
  }

  .lookbook-popup-overlay .popup-add-to-cart .cart-arrow svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .lookbook-popup-overlay .popup-add-to-cart:hover:not(:disabled) .cart-arrow {
    transform: translateX(4px);
  }

  .lookbook-popup-overlay .popup-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 16px;
  }

  .lookbook-popup-overlay .popup-spinner {
    width: 32px;
    height: 32px;
    border: 2px solid #f3f3f3;
    border-top: 2px solid #000;
    border-radius: 50%;
    animation: popup-spin 0.8s linear infinite;
  }

  @keyframes popup-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @media screen and (max-width: 1024px) {
    .lookbook-{{ section.id }} { padding-left: 20px; padding-right: 20px; }
    .lookbook-{{ section.id }} .lookbook-grid { gap: 16px; }
    .lookbook-{{ section.id }} .section-title { font-size: 30px; }
  }

  @media screen and (max-width: 749px) {
    .lookbook-{{ section.id }} { padding-left: 0; padding-right: 0; }
    .lookbook-{{ section.id }} .section-header { justify-content: center; padding: 0 16px; margin-bottom: 20px; max-width: 100%; }
    .lookbook-{{ section.id }} .section-title { font-size: 24px; text-align: center; max-width: 100%; }
    .lookbook-{{ section.id }} .lookbook-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4px; padding: 0 16px; max-width: 100%; margin: 0; }
    .lookbook-{{ section.id }} .lookbook-card { border-width: 1px; }
    .lookbook-{{ section.id }} .hotspot-btn { width: {{ section.settings.hotspot_size_mobile | default: 28 }}px; height: {{ section.settings.hotspot_size_mobile | default: 28 }}px; }
    .lookbook-{{ section.id }} .hotspot-btn .material-icon { width: {{ section.settings.hotspot_icon_size_mobile | default: 16 }}px; height: {{ section.settings.hotspot_icon_size_mobile | default: 16 }}px; }
    .lookbook-{{ section.id }} .hotspot-btn .hotspot-label { font-size: 10px; padding: 4px 10px; bottom: calc(100% + 8px); }
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::before,
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after { inset: -3px; }
    @keyframes hotspot-ripple-{{ section.id }} {
      0% { transform: scale(1); opacity: 0.6; }
      100% { transform: scale(1.4); opacity: 0; }
    }
    .lookbook-popup-overlay { padding: 10px; }
    .lookbook-popup-overlay .popup-wrapper { width: 100%; max-width: 400px; min-height: 447px; }
    .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label { padding: 6px 12px !important; font-size: 12px; min-height: 30px; }
    .lookbook-popup-overlay .popup-variant-picker .ui-custom-size-select { padding: 10px 32px 10px 12px; font-size: 13px; }
  }

  @media screen and (max-width: 400px) {
    .lookbook-popup-overlay .popup-wrapper { width: 100%; height: 100vh; max-height: 100vh; border-radius: 0; box-shadow: none; }
    .lookbook-popup-overlay { padding: 0; }
    .lookbook-popup-overlay .popup-body { padding: 30px 16px 16px 16px; }
    .lookbook-popup-overlay .popup-top { height: 130px; }
    .lookbook-popup-overlay .popup-image-wrapper { width: 100px; height: 130px; }
    .lookbook-popup-overlay .popup-info-wrapper { padding-top: 8px; }
    .lookbook-popup-overlay .popup-title { font-size: 14px; }
    .lookbook-popup-overlay .popup-price { font-size: 14px; }
    .lookbook-popup-overlay .popup-description { font-size: 12px; line-height: 1.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lookbook-{{ section.id }} .lookbook-card img { transition: none; }
    .lookbook-{{ section.id }} .hotspot-btn { transition: none; }
    .lookbook-{{ section.id }} .hotspot-btn:hover { transform: none; }
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::before,
    .lookbook-{{ section.id }} .hotspot-btn .ripple-animation::after { animation: none; }
    .lookbook-{{ section.id }} .hotspot-btn:hover .material-icon { transform: none; }
    .lookbook-popup-overlay .popup-wrapper { animation: none; }
    .lookbook-popup-overlay .popup-close { transition: none; }
    .lookbook-popup-overlay .popup-close:hover { transform: none; }
    .lookbook-popup-overlay .popup-add-to-cart { transition: none; }
    .lookbook-popup-overlay .popup-add-to-cart:hover:not(:disabled) { transform: none; }
    .lookbook-popup-overlay .popup-add-to-cart:hover:not(:disabled) .cart-arrow { transform: none; }
    .lookbook-popup-overlay .popup-swatch-option { transition: none; }
    .lookbook-popup-overlay .popup-variant-picker .variant-option__button-label { transition: none; }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding lookbook-{{ section.id }}">
  
  <div class="section-header">
    <h2 class="section-title">
      {{ section.settings.section_title | default: 'Tisso vison in the wild' }}
    </h2>
  </div>

  <div class="lookbook-grid">
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'image' -%}
          
          {%- liquid
            assign image = block.settings.image
            assign image_alt = block.settings.image_alt | default: image.alt | default: 'Gallery image'
            
            assign hs1_enable = block.settings.hotspot_1_enable
            assign hs1_product = block.settings.hotspot_1_product
            assign hs1_top = block.settings.hotspot_1_top | default: 50
            assign hs1_left = block.settings.hotspot_1_left | default: 50
            assign hs1_label = block.settings.hotspot_1_label
            assign hs1_mobile_top = block.settings.hotspot_1_mobile_top | default: hs1_top
            assign hs1_mobile_left = block.settings.hotspot_1_mobile_left | default: hs1_left
            
            assign hs2_enable = block.settings.hotspot_2_enable
            assign hs2_product = block.settings.hotspot_2_product
            assign hs2_top = block.settings.hotspot_2_top | default: 50
            assign hs2_left = block.settings.hotspot_2_left | default: 50
            assign hs2_label = block.settings.hotspot_2_label
            assign hs2_mobile_top = block.settings.hotspot_2_mobile_top | default: hs2_top
            assign hs2_mobile_left = block.settings.hotspot_2_mobile_left | default: hs2_left
            
            assign hs3_enable = block.settings.hotspot_3_enable
            assign hs3_product = block.settings.hotspot_3_product
            assign hs3_top = block.settings.hotspot_3_top | default: 50
            assign hs3_left = block.settings.hotspot_3_left | default: 50
            assign hs3_label = block.settings.hotspot_3_label
            assign hs3_mobile_top = block.settings.hotspot_3_mobile_top | default: hs3_top
            assign hs3_mobile_left = block.settings.hotspot_3_mobile_left | default: hs3_left
            
            assign hs4_enable = block.settings.hotspot_4_enable
            assign hs4_product = block.settings.hotspot_4_product
            assign hs4_top = block.settings.hotspot_4_top | default: 50
            assign hs4_left = block.settings.hotspot_4_left | default: 50
            assign hs4_label = block.settings.hotspot_4_label
            assign hs4_mobile_top = block.settings.hotspot_4_mobile_top | default: hs4_top
            assign hs4_mobile_left = block.settings.hotspot_4_mobile_left | default: hs4_left
            
            assign enable_ripple = section.settings.enable_ripple_animation | default: true
            assign ripple_class = ''
            if enable_ripple
              assign ripple_class = 'ripple-animation'
            endif
            
            assign hs1_show = false
            if hs1_enable and hs1_product != blank
              assign hs1_show = true
            endif
            
            assign hs2_show = false
            if hs2_enable and hs2_product != blank
              assign hs2_show = true
            endif
            
            assign hs3_show = false
            if hs3_enable and hs3_product != blank
              assign hs3_show = true
            endif
            
            assign hs4_show = false
            if hs4_enable and hs4_product != blank
              assign hs4_show = true
            endif
          -%}
          
          <div 
            class="lookbook-card" 
            {{ block.shopify_attributes }}
            data-block-type="image"
          >
            {%- if image != blank -%}
              <div class="media">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  srcset="
                    {{ image | image_url: width: 400 }} 400w,
                    {{ image | image_url: width: 600 }} 600w,
                    {{ image | image_url: width: 800 }} 800w,
                    {{ image | image_url: width: 1000 }} 1000w
                  "
                  sizes="(max-width: 749px) calc(50vw - 20px), (max-width: 1024px) calc(33vw - 30px), calc(33vw - 40px)"
                  alt="{{ image_alt | escape }}"
                  loading="lazy"
                >
              </div>
            {%- else -%}
              <div style="width:100%;height:100%;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#999;font-size:14px;padding:20px;text-align:center;aspect-ratio:1/1;">
                {{ 'onboarding.no_image' | t }}
                <br>
                <small>Add image in Theme Editor</small>
              </div>
            {%- endif -%}
            
            {%- if hs1_show -%}
              <button
                class="hotspot-btn {{ ripple_class }}"
                style="top: {{ hs1_top }}%; left: {{ hs1_left }}%;"
                data-product-id="{{ hs1_product.id }}"
                data-product-title="{{ hs1_product.title }}"
                aria-label="{{ hs1_label | default: 'View product' | escape }}"
                type="button"
              >
                {% render 'material-icon', icon: 'add' %}
                {%- if hs1_label != blank -%}
                  <span class="hotspot-label">{{ hs1_label }}</span>
                {%- endif -%}
              </button>
            {%- endif -%}
            
            {%- if hs2_show -%}
              <button
                class="hotspot-btn {{ ripple_class }}"
                style="top: {{ hs2_top }}%; left: {{ hs2_left }}%;"
                data-product-id="{{ hs2_product.id }}"
                data-product-title="{{ hs2_product.title }}"
                aria-label="{{ hs2_label | default: 'View product' | escape }}"
                type="button"
              >
                {% render 'material-icon', icon: 'add' %}
                {%- if hs2_label != blank -%}
                  <span class="hotspot-label">{{ hs2_label }}</span>
                {%- endif -%}
