<!-- ============================================================
     POPUP
     ============================================================ -->
<div id="lookbook-popup" class="lookbook-popup-overlay">
  <div class="popup-wrapper">
    
    <button class="popup-close" aria-label="{{ 'general.accessibility.close' | t }}">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L13 13M1 13L13 1" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    
    <div id="popup-body" class="popup-body">
      <!-- Popup content is filled by JavaScript -->
    </div>
    
  </div>
</div>

<!-- ============================================================
     JAVASCRIPT
     ============================================================ -->
<script>
  (function() {
    'use strict';
    
    var popup = document.getElementById('lookbook-popup');
    var popupBody = document.getElementById('popup-body');
    var closeBtn = popup.querySelector('.popup-close');
    var overlay = popup;
    
    var currentProductId = null;
    var currentVariantId = null;
    
    // ============================================================
    // HOTSPOT CLICKS
    // ============================================================
    document.querySelectorAll('.hotspot-btn[data-product-id]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var productId = this.dataset.productId;
        if (productId) {
          openPopup(productId);
        }
      });
      
      btn.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          var productId = this.dataset.productId;
          if (productId) {
            openPopup(productId);
          }
        }
      });
    });
    
    // ============================================================
    // CLOSE POPUP
    // ============================================================
    function closePopup() {
      popup.classList.remove('active');
      document.body.style.overflow = '';
    }
    
    closeBtn.addEventListener('click', closePopup);
    overlay.addEventListener('click', function(e) {
      if (e.target === this) {
        closePopup();
      }
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && popup.classList.contains('active')) {
        closePopup();
      }
    });
    
    // ============================================================
    // OPEN POPUP - FIXED with proper title handling
    // ============================================================
    function openPopup(productId) {
      currentProductId = productId;
      
      popupBody.innerHTML = '<div class="popup-loading"><div class="popup-spinner"></div><p style="font-family: \'Lustria\', serif; margin: 0;">Loading product...</p></div>';
      popup.classList.add('active');
      document.body.style.overflow = 'hidden';
      
      // First try to get from script tag
      var scriptEl = document.getElementById('product-json-' + productId);
      
      if (scriptEl) {
        try {
          var product = JSON.parse(scriptEl.textContent);
          if (product && product.title) {
            console.log('[Lookbook] Product title from script tag:', product.title);
            renderProduct(product);
            if (product.variants && product.variants.length > 0) {
              currentVariantId = product.variants[0].id;
            }
            return;
          }
        } catch (e) {
          console.warn('Error parsing product JSON:', e);
        }
      }
      
      // Fallback: fetch via AJAX
      fetch('/products/' + productId + '.js')
        .then(function(response) {
          if (!response.ok) throw new Error('Product not found');
          return response.json();
        })
        .then(function(product) {
          console.log('[Lookbook] Product title from AJAX:', product.title);
          renderProduct(product);
          if (product.variants && product.variants.length > 0) {
            currentVariantId = product.variants[0].id;
          }
        })
        .catch(function(error) {
          console.error('Error loading product:', error);
          showError();
        });
    }
    
    // ============================================================
    // RENDER PRODUCT - FIXED with proper title rendering
    // ============================================================
    function renderProduct(product) {
      console.log('[Lookbook] Rendering product with title:', product.title);
      
      var firstVariant = product.variants && product.variants.length > 0 ? product.variants[0] : null;
      var priceFormatted = firstVariant ? firstVariant.price_formatted : product.price_formatted;
      var isAvailable = firstVariant ? firstVariant.available : product.available;
      
      // Get product title - use the title directly from the product object
      var productTitle = product.title || 'Product';
      
      // If title is still empty, try to get from the script tag as fallback
      if (productTitle === 'Product' || productTitle === '') {
        var scriptEl = document.getElementById('product-json-' + currentProductId);
        if (scriptEl) {
          try {
            var productData = JSON.parse(scriptEl.textContent);
            if (productData && productData.title) {
              productTitle = productData.title;
              console.log('[Lookbook] Title from script tag fallback:', productTitle);
            }
          } catch (e) {}
        }
      }
      
      // If still no title, try to get from the hotspot button
      if (productTitle === 'Product' || productTitle === '') {
        var btn = document.querySelector('.hotspot-btn[data-product-id="' + currentProductId + '"]');
        if (btn && btn.dataset.productTitle) {
          productTitle = btn.dataset.productTitle;
          console.log('[Lookbook] Title from button data attribute:', productTitle);
        }
      }
      
      console.log('[Lookbook] Final product title:', productTitle);
      
      // Build description - full content
      var descText = product.description || '';
      var tempDiv = document.createElement('div');
      tempDiv.innerHTML = descText;
      descText = tempDiv.textContent || tempDiv.innerText || '';
      
      // Build variant picker
      var variantPickerHtml = buildVariantPicker(product);
      
      // Build add to cart button
      var addToCartText = isAvailable ? 'Add to Cart' : 'Sold Out';
      var disabledAttr = isAvailable ? '' : 'disabled';
      var cartArrow = '<span class="cart-arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>';
      
      popupBody.innerHTML = 
        '<div class="popup-top">' +
          '<div class="popup-image-wrapper">' +
            '<img src="' + product.featured_image + '" alt="' + productTitle + '" loading="lazy">' +
          '</div>' +
          '<div class="popup-info-wrapper">' +
            '<h2 class="popup-title">' + productTitle + '</h2>' +
            '<div class="popup-price">' + priceFormatted + '</div>' +
            (descText ? '<div class="popup-description" style="overflow:visible;max-height:none;">' + descText + '</div>' : '') +
          '</div>' +
        '</div>' +
        '<div class="popup-variant-picker">' +
          variantPickerHtml +
        '</div>' +
        '<form class="popup-form" onsubmit="return false;">' +
          '<button type="button" class="popup-add-to-cart" ' + disabledAttr + '>' + 
            addToCartText + cartArrow + 
          '</button>' +
        '</form>';
      
      // Verify the title was rendered
      var renderedTitle = popupBody.querySelector('.popup-title');
      if (renderedTitle) {
        console.log('[Lookbook] Rendered title text:', renderedTitle.textContent);
      }
      
      // Store product data
      popupBody._productData = product;
      
      // Initialize variant picker interactions
      initVariantPickerInteractions(product);
      
      // Initialize add to cart
      var addBtn = popupBody.querySelector('.popup-add-to-cart');
      if (addBtn) {
        addBtn.addEventListener('click', function(e) {
          e.preventDefault();
          handleAddToCart();
        });
      }
    }
    
    // ============================================================
    // BUILD VARIANT PICKER
    // ============================================================
    function buildVariantPicker(product) {
      if (!product.options || product.options.length === 0) {
        return '';
      }
      
      var html = '<div class="variant-picker spacing-style">';
      html += '<form class="variant-picker__form">';
      
      for (var o = 0; o < product.options.length; o++) {
        var option = product.options[o];
        var optionName = option.name;
        var optionNameDowncase = optionName.toLowerCase();
        var isSize = optionNameDowncase === 'size';
        
        html += '<fieldset class="variant-option variant-option--buttons">';
        html += '<legend>' + optionName + ' <span class="variant-option__swatch-value">' + option.values[0] + '</span></legend>';
        
        if (isSize) {
          html += '<div class="custom-dropdown-container">';
          html += '<select class="ui-custom-size-select" data-option-index="' + o + '">';
          for (var v = 0; v < option.values.length; v++) {
            var selected = (v === 0) ? 'selected' : '';
            html += '<option value="' + option.values[v] + '" ' + selected + '>' + option.values[v] + '</option>';
          }
          html += '</select>';
          html += '</div>';
        }
        
        html += '<div class="theme-native-inputs-wrapper" style="' + (isSize ? 'display:none;' : '') + '">';
        for (var v2 = 0; v2 < option.values.length; v2++) {
          var val = option.values[v2];
          var checked = (v2 === 0) ? 'checked' : '';
          
          html += '<label class="variant-option__button-label">';
          html += '<input type="radio" name="' + optionName + '" value="' + val + '" ' + checked + ' data-option-index="' + o + '" data-value="' + val + '">';
          html += '<span class="variant-option__button-label__text">' + val + '</span>';
          html += '</label>';
        }
        html += '</div>';
        
        html += '</fieldset>';
      }
      
      html += '</form>';
      html += '</div>';
      
      return html;
    }
    
    // ============================================================
    // INIT VARIANT PICKER INTERACTIONS
    // ============================================================
    function initVariantPickerInteractions(product) {
      var body = popupBody;
      
      var radioInputs = body.querySelectorAll('.variant-option input[type="radio"]');
      radioInputs.forEach(function(input) {
        input.addEventListener('change', function() {
          var fieldset = this.closest('fieldset');
          var legend = fieldset.querySelector('legend .variant-option__swatch-value');
          if (legend) {
            legend.textContent = this.value;
          }
          updateVariantFromSelections(body, product);
        });
      });
      
      var sizeSelects = body.querySelectorAll('.ui-custom-size-select');
      sizeSelects.forEach(function(select) {
        select.addEventListener('change', function() {
          var fieldset = this.closest('fieldset');
          var radios = fieldset.querySelectorAll('input[type="radio"]');
          for (var i = 0; i < radios.length; i++) {
            if (radios[i].value === this.value) {
              radios[i].checked = true;
              var legend = fieldset.querySelector('legend .variant-option__swatch-value');
              if (legend) {
                legend.textContent = this.value;
              }
              break;
            }
          }
          updateVariantFromSelections(body, product);
        });
      });
    }
    
    // ============================================================
    // UPDATE VARIANT FROM SELECTIONS
    // ============================================================
    function updateVariantFromSelections(body, product) {
      var selectedValues = [];
      var fieldsets = body.querySelectorAll('fieldset.variant-option');
      
      fieldsets.forEach(function(fieldset) {
        var checkedRadio = fieldset.querySelector('input[type="radio"]:checked');
        if (checkedRadio) {
          selectedValues.push(checkedRadio.value);
        } else {
          var select = fieldset.querySelector('.ui-custom-size-select');
          if (select) {
            selectedValues.push(select.value);
          }
        }
      });
      
      var matchedVariant = null;
      for (var i = 0; i < product.variants.length; i++) {
        var v = product.variants[i];
        var matches = true;
        for (var j = 0; j < selectedValues.length; j++) {
          if (v.options[j] !== selectedValues[j]) {
            matches = false;
            break;
          }
        }
        if (matches) {
          matchedVariant = v;
          break;
        }
      }
      
      if (matchedVariant) {
        var priceDisplay = body.querySelector('.popup-price');
        if (priceDisplay) {
          priceDisplay.textContent = matchedVariant.price_formatted;
        }
        
        var addBtn = body.querySelector('.popup-add-to-cart');
        if (addBtn) {
          var cartArrow = '<span class="cart-arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>';
          if (matchedVariant.available) {
            addBtn.disabled = false;
            addBtn.innerHTML = 'Add to Cart ' + cartArrow;
          } else {
            addBtn.disabled = true;
            addBtn.innerHTML = 'Sold Out';
          }
        }
        currentVariantId = matchedVariant.id;
      }
    }
    
    // ============================================================
    // ADD TO CART
    // ============================================================
    function handleAddToCart() {
      var addBtn = popupBody.querySelector('.popup-add-to-cart');
      
      if (!addBtn || addBtn.disabled) return;
      if (!currentVariantId) {
        var productData = popupBody._productData;
        if (productData && productData.variants && productData.variants.length > 0) {
          currentVariantId = productData.variants[0].id;
        }
        if (!currentVariantId) return;
      }
      
      var originalText = addBtn.innerHTML;
      addBtn.disabled = true;
      addBtn.innerHTML = 'Adding...';
      
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: parseInt(currentVariantId),
          quantity: 1
        })
      })
      .then(function(response) {
        if (!response.ok) throw new Error('Failed to add to cart');
        return response.json();
      })
      .then(function(data) {
        addBtn.innerHTML = '✓ Added!';
        addBtn.style.background = '#28a745';
        addBtn.style.color = '#FFFFFF';
        updateCartCount();
        setTimeout(function() {
          var cartArrow = '<span class="cart-arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>';
          var addToCartText = 'Add to Cart';
          addBtn.innerHTML = addToCartText + cartArrow;
          addBtn.disabled = false;
          addBtn.style.background = '#000000';
          addBtn.style.color = '#FFFFFF';
        }, 2000);
      })
      .catch(function(error) {
        console.error('Error adding to cart:', error);
        addBtn.innerHTML = 'Error - Try Again';
        addBtn.style.background = '#dc3545';
        addBtn.style.color = '#FFFFFF';
        setTimeout(function() {
          var cartArrow = '<span class="cart-arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>';
          var addToCartText = 'Add to Cart';
          addBtn.innerHTML = addToCartText + cartArrow;
          addBtn.disabled = false;
          addBtn.style.background = '#000000';
          addBtn.style.color = '#FFFFFF';
        }, 2000);
      });
    }
    
    function updateCartCount() {
      fetch('/cart.js')
        .then(function(response) { return response.json(); })
        .then(function(cart) {
          var count = cart.item_count || 0;
          document.querySelectorAll('.cart-count-bubble').forEach(function(el) {
            el.textContent = count;
          });
        })
        .catch(function() {});
    }
    
    function showError() {
      popupBody.innerHTML = '<div class="popup-loading"><p style="font-family:\'Lustria\',serif;">Unable to load product details. Please try again.</p><button style="margin-top:16px;padding:8px 24px;border:1px solid #000;background:transparent;cursor:pointer;border-radius:4px;" onclick="document.getElementById(\'lookbook-popup\').classList.remove(\'active\')">Close</button></div>';
    }
    
    if (window.Shopify && Shopify.designMode) {
      console.log('[LookbookGallery] Final version with fixed product title rendering');
    }
    
  })();
</script>

{% schema %}
{
  "name": "Lookbook Gallery",
  "tag": "section",
  "class": "section-lookbook",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
