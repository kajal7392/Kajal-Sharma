{% comment %}
  ================================================================
  SECTION: The Gift Guide Hero Banner with Dynamic Blocks
  VERSION: 3.0.0
  DESCRIPTION: Structural absolute alignments mapped precisely to Figma
               layer IDs with an intuitive Theme Editor interface.
  ================================================================
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign headline = section.settings.headline
  assign description = section.settings.description
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign subtitle = section.settings.subtitle
  
  assign text_color = section.settings.text_color
  assign button_bg = section.settings.button_bg
  assign button_text_color = section.settings.button_text_color
-%}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600&display=swap');
  
  .gift-guide-{{ section_id }} {
    max-width: 1440px;
    margin: 0 auto;
    font-family: 'Jost', sans-serif;
    position: relative;
    overflow: hidden;
  }

  /* --- BANNER WORKSPACE FRAME CONTAINER --- */
  .gift-guide-{{ section_id }} .hero-banner-container {
    position: relative;
    width: 100%;
    height: 780px; 
    background-color: transparent;
  }
  
  /* --- RECTANGLE 26168: FROSTED GLASS BACKGROUND OVERLAY --- */
  .gift-guide-{{ section_id }} .hero-glass-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 1440px;
    height: 780px;
    background: rgba(255, 255, 255, 0.20);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 1;
    pointer-events: none;
  }
  
  /* --- TEXT CONTENT SEGMENT (Frame 3-1166) --- */
  .gift-guide-{{ section_id }} .hero-text-content-wrapper {
    position: absolute;
    top: 442px;
    left: 550px;
    width: 890px;
    height: 402px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  
  .gift-guide-{{ section_id }} .main-headline {
    font-weight: 500;
    font-size: 70px;
    line-height: 1.1;
    color: {{ text_color }};
    margin: 0 0 20px 0;
    letter-spacing: 0px;
  }
  
  .gift-guide-{{ section_id }} .hero-description {
    max-width: 483px;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.4;
    color: {{ text_color }};
    margin: 0 0 35px 0;
  }
  
  /* --- INTERACTIVE CTA BUTTON --- */
  .gift-guide-{{ section_id }} .hero-cta-btn {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    background: {{ button_bg }};
    color: {{ button_text_color }};
    text-decoration: none;
    padding: 15px 30px;
    font-size: 16px;
    font-weight: 500;
    transition: opacity 0.2s ease-in-out;
  }
  
  .gift-guide-{{ section_id }} .hero-cta-btn:hover {
    opacity: 0.9;
  }

  .gift-guide-{{ section_id }} .cta-arrow-icon {
    margin-left: 15px;
    display: flex;
    align-items: center;
  }
  
  /* --- SUBTITLE LOWER PLACEMENT --- */
  .gift-guide-{{ section_id }} .hero-subtitle {
    margin-top: auto;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: {{ text_color }};
    text-transform: uppercase;
    margin-bottom: 0;
  }
  
  /* --- GRAPHIC IMAGE CANVAS ASSETS --- */
  .gift-guide-{{ section_id }} .vector-asset {
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }
  .gift-guide-{{ section_id }} .vector-asset img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  
  /* --- CLASS MAPPINGS FOR EXACT FIGMA OFFSETS --- */
  .gift-guide-{{ section_id }} .v-layer-1199 { top: 94.74px; left: 462.39px; width: 879.11px; height: 425.78px; }
  .gift-guide-{{ section_id }} .v-layer-1203 { top: 14.10px; left: 660.59px; width: 669.63px; height: 428.52px; }
  .gift-guide-{{ section_id }} .v-layer-1197 { top: 258.07px; left: 1083.56px; width: 305.38px; height: 276.01px; }
  .gift-guide-{{ section_id }} .v-layer-1204 { top: 23.69px; left: 1106.69px; width: 246.95px; height: 160.18px; }
  .gift-guide-{{ section_id }} .v-layer-1198 { top: 354.87px; left: 1166.37px; width: 171.10px; height: 162.24px; }
  .gift-guide-{{ section_id }} .v-layer-1201 { top: 364.59px; left: 629.25px; width: 137.02px; height: 136.91px; }
  .gift-guide-{{ section_id }} .v-layer-1196 { top: 252.60px; left: 1363.48px; width: 30.94px; height: 30.94px; }
  .gift-guide-{{ section_id }} .v-layer-1202 { top: 382.66px; left: 650.53px; width: 94.43px; height: 112.68px; }
  .gift-guide-{{ section_id }} .v-layer-1200 { top: 410.12px; left: 663.67px; width: 56.67px; height: 56.46px; }

  /* --- FLUID RESPONSIVE CALCULATION VIEWPORTS --- */
  @media screen and (max-width: 1439px) {
    .gift-guide-{{ section_id }} .hero-banner-container,
    .gift-guide-{{ section_id }} .hero-glass-overlay {
      height: 55vw;
    }
    .gift-guide-{{ section_id }} .hero-text-content-wrapper {
      top: 50%;
      left: 5%;
      transform: translateY(-50%);
      width: 45%;
      height: auto;
    }
    .gift-guide-{{ section_id }} .main-headline { font-size: 4.5vw; }
    .gift-guide-{{ section_id }} .hero-description { font-size: 1.4vw; }
    
    /* Dynamically downscale vector maps together relative to the viewport size */
    .gift-guide-{{ section_id }} .vector-asset {
      transform: scale(calc(100vw / 1440));
      transform-origin: top left;
    }
  }

  @media screen and (max-width: 767px) {
    .gift-guide-{{ section_id }} .hero-banner-container {
      height: auto;
      padding: 60px 20px;
      display: flex;
      flex-direction: column;
    }
    .gift-guide-{{ section_id }} .hero-glass-overlay,
    .gift-guide-{{ section_id }} .vector-asset {
      display: none !important;
    }
    .gift-guide-{{ section_id }} .hero-text-content-wrapper {
      position: relative;
      top: unset;
      left: unset;
      transform: unset;
      width: 100%;
    }
    .gift-guide-{{ section_id }} .main-headline { font-size: 36px; }
    .gift-guide-{{ section_id }} .hero-description { font-size: 16px; max-width: 100%; }
    .gift-guide-{{ section_id }} .hero-subtitle { margin-top: 40px; }
  }
{%- endstyle -%}

<section class="gift-guide-{{ section_id }}" aria-label="Hero Banner Section">
  <div class="hero-banner-container">
    <div class="hero-glass-overlay"></div>

    <!-- Render Vector Blocks Dynamic Placement Loop -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'vector_asset' and block.settings.vector_png != blank -%}
        <div class="vector-asset v-layer-{{ block.settings.layer_id }}" {{ block.shopify_attributes }}>
          <img 
            src="{{ block.settings.vector_png | image_url: width: 1200 }}" 
            alt="Decorative Artwork Layer {{ block.settings.layer_id }}" 
            loading="lazy"
          >
        </div>
      {%- endif -%}
    {%- endfor -%}

    <!-- Central Text Layer Frame Container -->
    <div class="hero-text-content-wrapper">
      <h1 class="main-headline">{{ headline | escape }}</h1>
      <p class="hero-description">{{ description | escape }}</p>
      
      <a href="{{ cta_link }}" class="hero-cta-btn">
        <span>{{ cta_text | escape }}</span>
        <span class="cta-arrow-icon" aria-hidden="true">
          <svg width="26" height="2" viewBox="0 0 26 2" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 1H24M24 1L20 5M24 1L20 -3" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
      </a>

      <p class="hero-subtitle">{{ subtitle | escape }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "The Gift Guide Hero",
  "tag": "section",
  "class": "index-section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Content Configurator"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Heading Title Text",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text Paragraph",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Footer Footnote Subtitle",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Redirection URL Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Style Color Elements"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Typography Primary Hex Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "CTA Button Background Base",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "CTA Text Base Color Fill",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "vector_asset",
      "name": "Vector Artwork Asset",
      "settings": [
        {
          "type": "image_picker",
          "id": "vector_png",
          "label": "Upload Vector Image (PNG)"
        },
        {
          "type": "select",
          "id": "layer_id",
          "label": "Target Figma Layer Match ID",
          "options": [
            { "value": "1199", "label": "Layer 1199 (Main structural frame - 879x425)" },
            { "value": "1203", "label": "Layer 1203 (Large asset path - 669x428)" },
            { "value": "1197", "label": "Layer 1197 (Medium asset segment - 305x276)" },
            { "value": "1204", "label": "Layer 1204 (Small asset accent - 246x160)" },
            { "value": "1198", "label": "Layer 1198 (Detailed line frame - 171x162)" },
            { "value": "1201", "label": "Layer 1201 (Circular ring profile - 137x136)" },
            { "value": "1196", "label": "Layer 1196 (Small dot element - 30x30)" },
            { "value": "1202", "label": "Layer 1202 (Medium context detail - 94x112)" },
            { "value": "1200", "label": "Layer 1200 (Small micro block - 56x56)" }
          ],
          "default": "1199"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "The Gift Guide Hero Banner",
      "blocks": [
        { "type": "vector_asset", "settings": { "layer_id": "1199" } },
        { "type": "vector_asset", "settings": { "layer_id": "1203" } }
      ]
    }
  ]
}
{% endschema %}