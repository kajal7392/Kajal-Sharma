{% comment %}
  ================================================================
  SECTION: The Gift Guide Hero - Mobile Content Above Image
  VERSION: 1.0.0
  DESCRIPTION: Mobile layout with content above the banner image
               - Desktop: Content overlaid on image
               - Mobile: Content on top, image below with padding
  AUTHOR: [Candidate Name]
  
  MOBILE LAYOUT:
  ┌──────────────────────────────────────────────────────────────┐
  │  "The Gift Guide" (Headline)                               │
  │  "Discover Joy..." (Description)                           │
  │  [SHOP NOW →] (CTA Button)                                │
  │  ────────────────────────────────────────────────────────   │
  │  BANNER IMAGE (with padding from content)                  │
  │  ────────────────────────────────────────────────────────   │
  │  BOTTOM CONTAINER (#F5F5F5)                               │
  └──────────────────────────────────────────────────────────────┘
  ================================================================
{% endcomment %}

{%- liquid
  # ============================================================
  # SECTION VARIABLES
  # ============================================================
  assign section_id = section.id
  
  # Banner background settings
  assign bg_image = section.settings.bg_image
  assign bg_image_mobile = section.settings.bg_image_mobile
  assign bg_color = section.settings.bg_color | default: '#FFFFFF'
  assign overlay_color = section.settings.overlay_color | default: '#FFFFFF'
  assign overlay_opacity = section.settings.overlay_opacity | default: 15
  
  # Banner content settings
  assign headline = section.settings.headline | default: 'The Gift Guide'
  assign description = section.settings.description | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.'
  assign cta_text = section.settings.cta_text | default: 'SHOP NOW'
  assign cta_link = section.settings.cta_link | default: '/collections/all'
  
  # Bottom container text
  assign bottom_text = section.settings.bottom_text | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL'
  assign bottom_bg = section.settings.bottom_bg | default: '#F5F5F5'
  assign bottom_text_color = section.settings.bottom_text_color | default: '#000000'
  
  # Color settings
  assign text_color = section.settings.text_color | default: '#000000'
  assign button_bg = section.settings.button_bg | default: '#000000'
  assign button_text_color = section.settings.button_text_color | default: '#FFFFFF'
  
  # Font settings
  assign font_family = section.settings.font_family | default: 'Jost'
-%}

<!-- ============================================================
     SECTION STYLES
     ============================================================ -->
{%- style -%}
  /* ============================================================
     FONT IMPORT (Jost)
     ============================================================ */
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&display=swap');
  
  /* ============================================================
     MASTER WRAPPER: Frame 1957
     ============================================================ */
  .gift-guide-{{ section_id }} {
    max-width: 1440px;
    margin: 0 auto;
    font-family: '{{ font_family }}', sans-serif;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  
  /* ============================================================
     BANNER CONTAINER - DESKTOP
     Dimensions: 1440px × 780px
     ============================================================ */
  .gift-guide-{{ section_id }} .banner-container {
    position: relative;
    width: 100%;
    height: 780px;
    min-height: 780px;
    background: {{ bg_color }};
    overflow: hidden;
    flex-shrink: 0;
  }
  
  /* Desktop banner background image */
  .gift-guide-{{ section_id }} .banner-container .banner-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  
  /* Mobile banner background image - hidden by default */
  .gift-guide-{{ section_id }} .banner-container .banner-bg-mobile {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    display: none;
  }
  
  {%- if bg_image != blank -%}
    .gift-guide-{{ section_id }} .banner-container {
      background-image: url('{{ bg_image | image_url: width: 1600 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
  {%- endif -%}
  
  /* Frosted glass overlay - Desktop only */
  .gift-guide-{{ section_id }} .banner-container .glass-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ overlay_color }};
    opacity: {{ overlay_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 1;
    pointer-events: none;
  }
  
  /* ============================================================
     BANNER CONTENT - DESKTOP (Centered over image)
     ============================================================ */
  .gift-guide-{{ section_id }} .banner-content {
    position: relative;
    z-index: 2;
    height: 100%;
    padding: 0 67px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  /* Desktop Main Headline */
  .gift-guide-{{ section_id }} .main-headline {
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 500;
    font-size: 70px;
    line-height: 70px;
    color: {{ text_color }};
    margin: 0 0 20px 0;
    padding: 0;
    letter-spacing: 0;
    max-width: 459px;
  }
  
  /* Desktop Description */
  .gift-guide-{{ section_id }} .hero-description {
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 140%;
    color: {{ text_color }};
    margin: 0 0 30px 0;
    padding: 0;
    letter-spacing: 0;
    max-width: 483px;
  }
  
  /* Desktop Primary CTA */
  .gift-guide-{{ section_id }} .primary-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 220px;
    height: 50px;
    background: {{ button_bg }};
    color: {{ button_text_color }};
    text-decoration: none;
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }
  
  .gift-guide-{{ section_id }} .primary-cta .cta-content {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 0 16px;
  }
  
  .gift-guide-{{ section_id }} .primary-cta .cta-arrow {
    width: 25.51px;
    height: 0;
    border-top: 1.5px solid {{ button_text_color }};
    display: inline-block;
    position: relative;
  }
  
  .gift-guide-{{ section_id }} .primary-cta .cta-arrow::after {
    content: '';
    position: absolute;
    right: -4px;
    top: -4px;
    width: 8px;
    height: 8px;
    border-right: 1.5px solid {{ button_text_color }};
    border-top: 1.5px solid {{ button_text_color }};
    transform: rotate(45deg);
  }
  
  .gift-guide-{{ section_id }} .primary-cta:hover {
    opacity: 0.85;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  
  /* ============================================================
     BOTTOM CONTAINER
     Dimensions: 1440px × 34px | Background: #F5F5F5
     ============================================================ */
  .gift-guide-{{ section_id }} .bottom-container {
    width: 100%;
    height: 34px;
    min-height: 34px;
    background: {{ bottom_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 50px;
    box-sizing: border-box;
    flex-shrink: 0;
  }
  
  .gift-guide-{{ section_id }} .bottom-container .bottom-text {
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    color: {{ bottom_text_color }};
    letter-spacing: 0;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  
  /* ============================================================
     RESPONSIVE ADAPTATIONS - TABLET
     ============================================================ */
  
  @media screen and (max-width: 1024px) {
    .gift-guide-{{ section_id }} .banner-container {
      height: 600px;
      min-height: 600px;
    }
    
    .gift-guide-{{ section_id }} .banner-content {
      padding: 0 40px;
    }
    
    .gift-guide-{{ section_id }} .main-headline {
      font-size: 50px;
      line-height: 50px;
      max-width: 350px;
    }
    
    .gift-guide-{{ section_id }} .hero-description {
      font-size: 18px;
      max-width: 350px;
    }
    
    .gift-guide-{{ section_id }} .bottom-container .bottom-text {
      font-size: 14px;
    }
  }
  
  /* ============================================================
     RESPONSIVE ADAPTATIONS - MOBILE (max-width: 749px)
     LAYOUT: Content above image with padding
     ============================================================ */
  
  @media screen and (max-width: 749px) {
    /* Reset desktop styles */
    .gift-guide-{{ section_id }} .banner-container {
      height: auto;
      min-height: auto;
      background: {{ bg_color }};
    }
    
    /* Show mobile background image */
    .gift-guide-{{ section_id }} .banner-container .banner-bg {
      display: none;
    }
    
    .gift-guide-{{ section_id }} .banner-container .banner-bg-mobile {
      display: block;
      position: relative;
      width: 100%;
      height: auto;
      aspect-ratio: 375 / 280;
      object-fit: cover;
    }
    
    /* Hide desktop overlay on mobile */
    .gift-guide-{{ section_id }} .banner-container .glass-overlay {
      display: none;
    }
    
    /* Content section - above image with padding */
    .gift-guide-{{ section_id }} .banner-content {
      position: relative;
      z-index: 2;
      height: auto;
      padding: 40px 20px 30px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      justify-content: flex-start;
      background: {{ bg_color }};
    }
    
    /* Mobile Main Headline */
    .gift-guide-{{ section_id }} .main-headline {
      font-family: '{{ font_family }}', sans-serif;
      font-weight: 500;
      font-size: 30px;
      line-height: 30px;
      color: {{ text_color }};
      margin: 0 0 12px 0;
      padding: 0;
      letter-spacing: 0;
      max-width: 100%;
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: auto;
      height: auto;
    }
    
    /* Mobile Description */
    .gift-guide-{{ section_id }} .hero-description {
      font-family: '{{ font_family }}', sans-serif;
      font-weight: 400;
      font-size: 16px;
      line-height: 130%;
      color: {{ text_color }};
      margin: 0 0 30px 0;
      padding: 0;
      letter-spacing: 0;
      max-width: 100%;
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: auto;
      height: auto;
    }
    
    /* Mobile Primary CTA */
    .gift-guide-{{ section_id }} .primary-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 193px;
      height: 45px;
      min-height: 45px;
      background: {{ button_bg }};
      color: {{ button_text_color }};
      text-decoration: none;
      font-family: '{{ font_family }}', sans-serif;
      font-weight: 400;
      font-size: 16px;
      line-height: 20.48px;
      letter-spacing: 0;
      transition: all 0.3s ease;
      cursor: pointer;
      border: none;
      position: relative;
      top: 50%s;
      left: auto;
      transform: none;
      padding: 13px 20px;
      gap: 10px;
      margin: 0 auto;
    }
    
    .gift-guide-{{ section_id }} .primary-cta .cta-content {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0;
    }
    
    .gift-guide-{{ section_id }} .primary-cta .cta-arrow {
      width: 20px;
      height: 0;
      border-top: 1.5px solid {{ button_text_color }};
      display: inline-block;
      position: relative;
    }
    
    .gift-guide-{{ section_id }} .primary-cta .cta-arrow::after {
      content: '';
      position: absolute;
      right: -4px;
      top: -4px;
      width: 7px;
      height: 7px;
      border-right: 1.5px solid {{ button_text_color }};
      border-top: 1.5px solid {{ button_text_color }};
      transform: rotate(45deg);
    }
    
    .gift-guide-{{ section_id }} .primary-cta:hover {
      opacity: 0.85;
      transform: translateY(-2px);
    }
    
    /* Mobile image wrapper - sits below content */
    .gift-guide-{{ section_id }} .banner-container .mobile-image-wrapper {
      position: relative;
      width: 100%;
      padding: 0 16px 20px 16px;
      box-sizing: border-box;
      background: {{ bg_color }};
    }
    
    .gift-guide-{{ section_id }} .banner-container .mobile-image-wrapper img {
      width: 100%;
      height: auto;
      aspect-ratio: 343 / 240;
      object-fit: cover;
      border-radius: 0;
      display: block;
    }
    
    /* Mobile Bottom Container */
    .gift-guide-{{ section_id }} .bottom-container {
      height: auto;
      min-height: 34px;
      padding: 8px 20px;
    }
    
    .gift-guide-{{ section_id }} .bottom-container .bottom-text {
      font-size: 12px;
      line-height: 14px;
      white-space: normal;
    }
  }
  
  /* ============================================================
     RESPONSIVE ADAPTATIONS - SMALL MOBILE (max-width: 480px)
     ============================================================ */
  
  @media screen and (max-width: 480px) {
    .gift-guide-{{ section_id }} .banner-content {
      padding: 30px 16px 20px 16px;
    }
    
    .gift-guide-{{ section_id }} .main-headline {
      font-size: 26px;
      line-height: 26px;
    }
    
    .gift-guide-{{ section_id }} .hero-description {
      font-size: 14px;
      line-height: 130%;
    }
    
    .gift-guide-{{ section_id }} .primary-cta {
      width: 170px;
      height: 42px;
      min-height: 42px;
      font-size: 14px;
      padding: 11px 16px;
    }
    
    .gift-guide-{{ section_id }} .banner-container .mobile-image-wrapper {
      padding: 0 12px 16px 12px;
    }
    
    .gift-guide-{{ section_id }} .banner-container .mobile-image-wrapper img {
      aspect-ratio: 343 / 220;
    }
    
    .gift-guide-{{ section_id }} .bottom-container .bottom-text {
      font-size: 10px;
      line-height: 12px;
    }
  }
{%- endstyle -%}

<!-- ============================================================
     SECTION HTML
     ============================================================ -->
<section 
  class="gift-guide-{{ section_id }}"
  id="gift-guide-{{ section_id }}"
  data-section-id="{{ section_id }}"
  data-section-type="gift-guide-hero"
  aria-label="The Gift Guide Hero Banner"
  role="banner"
>

  <!-- ============================================================
     CONTAINER 1: BANNER
     ============================================================ -->
  <div class="banner-container">
    
    <!-- Desktop Background Image (overlay) -->
    {%- if bg_image != blank -%}
      <img 
        src="{{ bg_image | image_url: width: 1600 }}"
        srcset="
          {{ bg_image | image_url: width: 375 }} 375w,
          {{ bg_image | image_url: width: 750 }} 750w,
          {{ bg_image | image_url: width: 1100 }} 1100w,
          {{ bg_image | image_url: width: 1600 }} 1600w
        "
        sizes="(min-width: 750px) 1600px, 100vw"
        alt="Background banner image"
        class="banner-bg"
        loading="lazy"
      >
    {%- endif -%}
    
    <!-- Frosted Glass Overlay (Desktop only) -->
    <div class="glass-overlay" aria-hidden="true"></div>
    
    <!-- ============================================================
         BANNER CONTENT - Desktop: Overlaid | Mobile: Above image
         ============================================================ -->
    <div class="banner-content">
      
      <!-- Main Headline -->
      <h1 class="main-headline">
        {{ headline }}
      </h1>
      
      <!-- Description -->
      <p class="hero-description">
        {{ description }}
      </p>
      
      <!-- Primary CTA -->
      <a 
        href="{{ cta_link }}"
        class="primary-cta"
        aria-label="{{ cta_text | escape }}"
      >
        <span class="cta-content">
          {{ cta_text }}
          <span class="cta-arrow" aria-hidden="true"></span>
        </span>
      </a>
      
    </div>
    
    <!-- ============================================================
         MOBILE IMAGE - Below content with padding
         ============================================================ -->
    <div class="mobile-image-wrapper">
      {%- if bg_image_mobile != blank -%}
        <img 
          src="{{ bg_image_mobile | image_url: width: 750 }}"
          srcset="
            {{ bg_image_mobile | image_url: width: 375 }} 375w,
            {{ bg_image_mobile | image_url: width: 750 }} 750w
          "
          sizes="(max-width: 749px) 100vw, 0"
          alt="Mobile background banner image"
          loading="lazy"
        >
      {%- elsif bg_image != blank -%}
        <!-- Fallback to desktop image if mobile image not set -->
        <img 
          src="{{ bg_image | image_url: width: 750 }}"
          srcset="
            {{ bg_image | image_url: width: 375 }} 375w,
            {{ bg_image | image_url: width: 750 }} 750w
          "
          sizes="(max-width: 749px) 100vw, 0"
          alt="Background banner image"
          loading="lazy"
        >
      {%- endif -%}
    </div>
    
  </div>

  <!-- ============================================================
     CONTAINER 2: BOTTOM
     ============================================================ -->
  <div class="bottom-container">
    <span class="bottom-text">
      {{ bottom_text }}
    </span>
  </div>

</section>

<!-- ============================================================
     SECTION SCHEMA
     ============================================================ -->
{% schema %}
{
  "name": "The Gift Guide Hero",
  "tag": "section",
  "class": "gift-guide-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "🖼️ Banner Background Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Desktop Background Image",
      "info": "Recommended size: 1440px × 780px. Appears behind content on desktop."
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Mobile Banner Image",
      "info": "Recommended size: 375px × 280px. Appears below content on mobile with padding."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Banner Background Color",
      "default": "#FFFFFF",
      "info": "Background color for content area"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color (Desktop only)",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (Desktop only)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 15,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "📝 Banner Content Settings"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Main Headline",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "📝 Bottom Container Settings"
    },
    {
      "type": "color",
      "id": "bottom_bg",
      "label": "Bottom Container Background",
      "default": "#F5F5F5"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "color",
      "id": "bottom_text_color",
      "label": "Bottom Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "🎨 Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Primary Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Primary Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "📐 Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "options": [
        { "value": "Jost", "label": "Jost" },
        { "value": "Inter", "label": "Inter" },
        { "value": "Helvetica Neue", "label": "Helvetica Neue" },
        { "value": "Arial", "label": "Arial" }
      ],
      "default": "Jost"
    }
  ],
  "presets": [
    {
      "name": "The Gift Guide Hero",
      "category": "Custom Sections",
      "settings": {
        "headline": "The Gift Guide",
        "description": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.",
        "cta_text": "SHOP NOW",
        "bottom_text": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL",
        "bottom_bg": "#F5F5F5",
        "text_color": "#000000",
        "bottom_text_color": "#000000",
        "button_bg": "#000000",
        "button_text_color": "#FFFFFF",
        "bg_color": "#FFFFFF",
        "overlay_color": "#FFFFFF",
        "overlay_opacity": 15
      }
    }
  ]
}
{% endschema %}