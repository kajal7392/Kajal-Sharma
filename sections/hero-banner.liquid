{% comment %}
  ================================================================
  SECTION: The Gift Guide Hero Banner with Fixed Header
  VERSION: 1.0.0
  DESCRIPTION: Fixed header center text alignment issues
  AUTHOR: [Candidate Name]
  
  FIXES APPLIED:
  - Header center text now properly centered vertically (10px padding)
  - Text no longer gets cut off horizontally
  - Proper flex alignment with align-items: center
  - Responsive text sizing for all screen sizes
  - Text overflow handling with ellipsis
  
  FIGMA SPECIFICATIONS:
  - Frame 1957: 1440px × 878px master wrapper
  - Header: 1440px × 64px with horizontal auto-layout
  - Header padding: 10px top/bottom, 50px left/right
  - Gap between elements: 360px
  - Center text: "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
  ================================================================
{% endcomment %}

{%- liquid
  # ============================================================
  # SECTION VARIABLES
  # ============================================================
  assign section_id = section.id
  
  # Header settings
  assign header_bg = section.settings.header_bg | default: '#F5F5F5'
  assign header_gap = section.settings.header_gap | default: 360
  
  # Header center text (now using the correct text)
  assign header_center_text = section.settings.header_center_text | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL'
  
  # Header button settings
  assign header_button_text = section.settings.header_button_text | default: 'CHOOSE GIFT'
  assign header_button_link = section.settings.header_button_link | default: '/collections'
  assign header_button_bg = section.settings.header_button_bg | default: '#FFF544'
  assign header_button_text_color = section.settings.header_button_text_color | default: '#000000'
  
  # Background settings
  assign bg_image = section.settings.bg_image
  assign bg_color = section.settings.bg_color | default: '#FFFFFF'
  assign overlay_color = section.settings.overlay_color | default: '#FFFFFF'
  assign overlay_opacity = section.settings.overlay_opacity | default: 15
  
  # Hero content settings
  assign headline = section.settings.headline | default: 'The Gift Guide'
  assign description = section.settings.description | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.'
  assign cta_text = section.settings.cta_text | default: 'SHOP NOW'
  assign cta_link = section.settings.cta_link | default: '/collections/all'
  assign subtitle = section.settings.subtitle | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL'
  
  # Color settings
  assign text_color = section.settings.text_color | default: '#000000'
  assign button_bg = section.settings.button_bg | default: '#000000'
  assign button_text_color = section.settings.button_text_color | default: '#FFFFFF'
  
  # Font settings
  assign font_family = section.settings.font_family | default: 'Jost'
-%}

<!-- ============================================================
     SECTION STYLES
     ============================================================ -->
{%- style -%}
  /* ============================================================
     FONT IMPORT (Jost)
     ============================================================ */
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&display=swap');
  
  /* ============================================================
     MASTER WRAPPER: Frame 1957
     Dimensions: 1440px × 878px
     ============================================================ */
  .gift-guide-{{ section_id }} {
    max-width: 1440px;
    margin: 0 auto;
    background: {{ header_bg }};
    font-family: '{{ font_family }}', sans-serif;
    position: relative;
    overflow: hidden;
  }
  
  /* ============================================================
     HEADER COMPONENT: Frame 1957 (Header)
     Dimensions: 1440px × 64px
     Auto Layout: Horizontal flow
     Padding: 10px 50px
     Gap: 360px
     Background: #F5F5F5
     FIX: Proper vertical centering with align-items: center
     ============================================================ */
  .gift-guide-{{ section_id }} .header-component {
    width: 100%;
    height: 64px;
    min-height: 64px;
    background: {{ header_bg }};
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 10px 50px;
    gap: {{ header_gap }}px;
    position: relative;
    z-index: 10;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    box-sizing: border-box;
  }
  
  /* ============================================================
     HEADER LOGO: "TISSO VISON" as text
     Dimensions: 151.44px × 19px
     ============================================================ */
  .gift-guide-{{ section_id }} .header-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    height: 100%;
  }
  
  .gift-guide-{{ section_id }} .header-logo .logo-text {
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 19px;
    color: {{ text_color }};
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  
  .gift-guide-{{ section_id }} .header-logo .logo-text .tisso {
    font-weight: 600;
  }
  
  .gift-guide-{{ section_id }} .header-logo .logo-text .vison {
    font-weight: 400;
    margin-left: 2px;
  }
  
  /* ============================================================
     HEADER CENTER TEXT - FIXED
     Text: "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
     Proper horizontal and vertical centering
     ============================================================ */
  .gift-guide-{{ section_id }} .header-center-text {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-width: 0;
    padding: 0 10px;
  }
  
  .gift-guide-{{ section_id }} .header-center-text .center-text-content {
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    color: {{ text_color }};
    letter-spacing: 0;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    padding: 0 5px;
  }
  
  /* ============================================================
     HEADER RIGHT BUTTON: "CHOOSE GIFT →"
     Dimensions: 207px × 44px
     Background: #FFF544
     ============================================================ */
  .gift-guide-{{ section_id }} .header-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 207px;
    min-width: 120px;
    height: 44px;
    background: {{ header_button_bg }};
    text-decoration: none;
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    color: {{ header_button_text_color }};
    transition: all 0.3s ease;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    border: none;
  }
  
  .gift-guide-{{ section_id }} .header-button .button-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 0 16px;
    width: 100%;
    height: 100%;
  }
  
  .gift-guide-{{ section_id }} .header-button .button-text {
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    color: {{ header_button_text_color }};
    letter-spacing: 0;
    white-space: nowrap;
  }
  
  .gift-guide-{{ section_id }} .header-button .button-arrow {
    width: 24px;
    height: 0;
    border-top: 1.5px solid {{ header_button_text_color }};
    display: inline-block;
    position: relative;
    flex-shrink: 0;
  }
  
  .gift-guide-{{ section_id }} .header-button .button-arrow::after {
    content: '';
    position: absolute;
    right: -4px;
    top: -4px;
    width: 8px;
    height: 8px;
    border-right: 1.5px solid {{ header_button_text_color }};
    border-top: 1.5px solid {{ header_button_text_color }};
    transform: rotate(45deg);
  }
  
  .gift-guide-{{ section_id }} .header-button:hover {
    opacity: 0.85;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }
  
  /* ============================================================
     BACKGROUND CANVAS: Rectangle 26167
     Dimensions: 1440px × 780px, Top: 64px
     ============================================================ */
  .gift-guide-{{ section_id }} .background-canvas {
    position: absolute;
    top: 64px;
    left: 0;
    width: 100%;
    height: 780px;
    background: {{ bg_color }};
    z-index: 0;
    overflow: hidden;
  }
  
  .gift-guide-{{ section_id }} .background-canvas .bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  
  {%- if bg_image != blank -%}
    .gift-guide-{{ section_id }} .background-canvas {
      background-image: url('{{ bg_image | image_url: width: 1600 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
  {%- endif -%}
  
  /* ============================================================
     FROSTED GLASS OVERLAY: Rectangle 26168
     Dimensions: 1440px × 780px, Top: 64px
     ============================================================ */
  .gift-guide-{{ section_id }} .glass-overlay {
    position: absolute;
    top: 64px;
    left: 0;
    width: 100%;
    height: 780px;
    background: {{ overlay_color }};
    opacity: {{ overlay_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 1;
    pointer-events: none;
  }
  
  /* ============================================================
     HERO CONTENT AREA: Frame 1956
     Dimensions: 1440px × 814px
     ============================================================ */
  .gift-guide-{{ section_id }} .hero-container {
    position: relative;
    min-height: 814px;
    padding: 0;
    z-index: 2;
  }
  
  /* ============================================================
     TEXT CONTENT - EXACT FIGMA POSITIONING
     ============================================================ */
  
  /* Main Headline: 459px × 70px at (67px, 489px) */
  .gift-guide-{{ section_id }} .main-headline {
    position: absolute;
    top: 489px;
    left: 67px;
    width: 459px;
    height: 70px;
    z-index: 3;
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 500;
    font-size: 70px;
    line-height: 70px;
    color: {{ text_color }};
    margin: 0;
    padding: 0;
    letter-spacing: 0;
  }
  
  /* Description: 483px × 84px at (67px, 609px) */
  .gift-guide-{{ section_id }} .hero-description {
    position: absolute;
    top: 609px;
    left: 67px;
    width: 483px;
    height: 84px;
    z-index: 3;
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 140%;
    color: {{ text_color }};
    margin: 0;
    padding: 0;
    letter-spacing: 0;
  }
  
  /* Primary CTA: 220px × 50px at (67px, 739px) */
  .gift-guide-{{ section_id }} .primary-cta {
    position: absolute;
    top: 739px;
    left: 67px;
    width: 220px;
    height: 50px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ button_bg }};
    color: {{ button_text_color }};
    text-decoration: none;
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }
  
  .gift-guide-{{ section_id }} .primary-cta .cta-content {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 0 16px;
  }
  
  .gift-guide-{{ section_id }} .primary-cta .cta-arrow {
    width: 25.51px;
    height: 0;
    border-top: 1.5px solid {{ button_text_color }};
    display: inline-block;
    position: relative;
  }
  
  .gift-guide-{{ section_id }} .primary-cta .cta-arrow::after {
    content: '';
    position: absolute;
    right: -4px;
    top: -4px;
    width: 8px;
    height: 8px;
    border-right: 1.5px solid {{ button_text_color }};
    border-top: 1.5px solid {{ button_text_color }};
    transform: rotate(45deg);
  }
  
  .gift-guide-{{ section_id }} .primary-cta:hover {
    opacity: 0.85;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  
  /* Footnote Subtitle: 451px × 14px at bottom: 44px, left: 67px */
  .gift-guide-{{ section_id }} .hero-subtitle {
    position: absolute;
    bottom: 44px;
    left: 67px;
    width: 451px;
    height: 14px;
    z-index: 3;
    font-family: '{{ font_family }}', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    color: {{ text_color }};
    margin: 0;
    padding: 0;
    letter-spacing: 0;
    opacity: 0.7;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  /* ============================================================
     RESPONSIVE ADAPTATIONS
     ============================================================ */
  
  @media screen and (max-width: 1024px) {
    .gift-guide-{{ section_id }} .header-component {
      padding: 10px 30px;
      gap: 30px;
    }
    
    .gift-guide-{{ section_id }} .header-center-text .center-text-content {
      font-size: 13px;
      line-height: 14px;
    }
    
    .gift-guide-{{ section_id }} .header-button {
      width: 160px;
      height: 40px;
      font-size: 14px;
    }
    
    .gift-guide-{{ section_id }} .header-button .button-text {
      font-size: 14px;
    }
    
    .gift-guide-{{ section_id }} .main-headline {
      top: 350px;
      left: 40px;
      width: 350px;
      font-size: 50px;
      line-height: 50px;
    }
    
    .gift-guide-{{ section_id }} .hero-description {
      top: 430px;
      left: 40px;
      width: 350px;
      height: auto;
      font-size: 18px;
    }
    
    .gift-guide-{{ section_id }} .primary-cta {
      top: 560px;
      left: 40px;
    }
    
    .gift-guide-{{ section_id }} .hero-subtitle {
      bottom: 30px;
      left: 40px;
      width: 300px;
      font-size: 14px;
      white-space: normal;
    }
    
    .gift-guide-{{ section_id }} .background-canvas,
    .gift-guide-{{ section_id }} .glass-overlay {
      height: 100%;
      min-height: 780px;
    }
  }
  
  @media screen and (max-width: 900px) {
    .gift-guide-{{ section_id }} .header-component {
      gap: 20px;
      padding: 10px 20px;
    }
    
    .gift-guide-{{ section_id }} .header-center-text .center-text-content {
      font-size: 12px;
      line-height: 13px;
    }
    
    .gift-guide-{{ section_id }} .header-button {
      width: 140px;
      height: 38px;
      font-size: 13px;
    }
    
    .gift-guide-{{ section_id }} .header-button .button-text {
      font-size: 13px;
    }
  }
  
  @media screen and (max-width: 749px) {
    .gift-guide-{{ section_id }} .header-component {
      padding: 8px 16px;
      gap: 12px;
      height: auto;
      min-height: 56px;
      flex-wrap: wrap;
    }
    
    .gift-guide-{{ section_id }} .header-logo .logo-text {
      font-size: 14px;
    }
    
    .gift-guide-{{ section_id }} .header-center-text {
      order: 3;
      flex: 0 0 100%;
      padding: 4px 0;
      height: auto;
      min-height: 20px;
    }
    
    .gift-guide-{{ section_id }} .header-center-text .center-text-content {
      font-size: 11px;
      line-height: 12px;
      white-space: normal;
      text-overflow: clip;
      padding: 0 20px;
    }
    
    .gift-guide-{{ section_id }} .header-button {
      width: 120px;
      height: 34px;
      font-size: 11px;
      min-width: 100px;
    }
    
    .gift-guide-{{ section_id }} .header-button .button-text {
      font-size: 11px;
    }
    
    .gift-guide-{{ section_id }} .header-button .button-arrow {
      width: 16px;
    }
    
    .gift-guide-{{ section_id }} .hero-container {
      min-height: 600px;
    }
    
    .gift-guide-{{ section_id }} .main-headline {
      top: 200px;
      left: 20px;
      width: calc(100% - 40px);
      height: auto;
      font-size: 32px;
      line-height: 36px;
      text-align: center;
    }
    
    .gift-guide-{{ section_id }} .hero-description {
      top: 260px;
      left: 20px;
      width: calc(100% - 40px);
      height: auto;
      font-size: 16px;
      text-align: center;
    }
    
    .gift-guide-{{ section_id }} .primary-cta {
      top: 420px;
      left: 50%;
      transform: translateX(-50%);
      width: 200px;
      height: 48px;
    }
    
    .gift-guide-{{ section_id }} .primary-cta:hover {
      transform: translateX(-50%) translateY(-2px);
    }
    
    .gift-guide-{{ section_id }} .hero-subtitle {
      bottom: 20px;
      left: 20px;
      width: calc(100% - 40px);
      height: auto;
      text-align: center;
      font-size: 12px;
      white-space: normal;
    }
    
    .gift-guide-{{ section_id }} .background-canvas,
    .gift-guide-{{ section_id }} .glass-overlay {
      height: 100%;
      min-height: 600px;
    }
  }
  
  @media screen and (max-width: 480px) {
    .gift-guide-{{ section_id }} .header-component {
      gap: 8px;
      padding: 6px 10px;
    }
    
    .gift-guide-{{ section_id }} .header-logo .logo-text {
      font-size: 11px;
    }
    
    .gift-guide-{{ section_id }} .header-button {
      width: 100px;
      height: 30px;
      font-size: 10px;
      min-width: 80px;
    }
    
    .gift-guide-{{ section_id }} .header-button .button-text {
      font-size: 10px;
    }
    
    .gift-guide-{{ section_id }} .header-button .button-arrow {
      width: 14px;
    }
    
    .gift-guide-{{ section_id }} .header-center-text .center-text-content {
      font-size: 10px;
      line-height: 11px;
    }
    
    .gift-guide-{{ section_id }} .main-headline {
      font-size: 26px;
      line-height: 30px;
      top: 160px;
    }
    
    .gift-guide-{{ section_id }} .hero-description {
      font-size: 14px;
      top: 220px;
    }
    
    .gift-guide-{{ section_id }} .primary-cta {
      top: 380px;
      width: 180px;
      height: 44px;
      font-size: 14px;
    }
  }
{%- endstyle -%}

<!-- ============================================================
     SECTION HTML
     ============================================================ -->
<section 
  class="gift-guide-{{ section_id }}"
  id="gift-guide-{{ section_id }}"
  data-section-id="{{ section_id }}"
  data-section-type="gift-guide-hero"
  aria-label="The Gift Guide Hero Banner"
  role="banner"
>

  <!-- ============================================================
       HEADER: 1440px × 64px with Auto Layout
       Padding: 10px 50px | Gap: 360px
       FIX: Proper vertical centering with display:flex + align-items:center
       ============================================================ -->
  <header class="header-component" role="banner" aria-label="Site header">
    
    <!-- Header Logo: "TISSO VISON" as text -->
    <div class="header-logo" aria-label="TISSO VISON logo">
      <span class="logo-text">
        <span class="tisso">TISSO</span>
        <span class="vison">VISON</span>
      </span>
    </div>
    
    <!-- Header Center Text - FIXED: Proper centering -->
    <div class="header-center-text">
      <span class="center-text-content">
        {{ header_center_text }}
      </span>
    </div>
    
    <!-- Header Right Button: "CHOOSE GIFT →" -->
    <a 
      href="{{ header_button_link }}"
      class="header-button"
      aria-label="{{ header_button_text | escape }}"
    >
      <span class="button-content">
        <span class="button-text">{{ header_button_text }}</span>
        <span class="button-arrow" aria-hidden="true"></span>
      </span>
    </a>
    
  </header>

  <!-- ============================================================
       BACKGROUND CANVAS: Rectangle 26167
       Dimensions: 1440px × 780px, Top: 64px
       ============================================================ -->
  <div class="background-canvas" aria-hidden="true">
    {%- if bg_image != blank -%}
      <img 
        src="{{ bg_image | image_url: width: 1600 }}"
        srcset="
          {{ bg_image | image_url: width: 375 }} 375w,
          {{ bg_image | image_url: width: 750 }} 750w,
          {{ bg_image | image_url: width: 1100 }} 1100w,
          {{ bg_image | image_url: width: 1600 }} 1600w
        "
        sizes="(max-width: 749px) 100vw, 1600px"
        alt="Background banner image"
        class="bg-image"
        loading="lazy"
      >
    {%- endif -%}
  </div>

  <!-- ============================================================
       FROSTED GLASS OVERLAY: Rectangle 26168
       ============================================================ -->
  <div class="glass-overlay" aria-hidden="true"></div>

  <!-- ============================================================
       HERO CONTENT AREA: Frame 1956
       ============================================================ -->
  <div class="hero-container">
    
    <!-- ============================================================
         TEXT CONTENT - EXACT FIGMA POSITIONING
         ============================================================ -->
    
    <!-- Main Headline -->
    <h1 class="main-headline">
      {{ headline }}
    </h1>
    
    <!-- Description -->
    <p class="hero-description">
      {{ description }}
    </p>
    
    <!-- Primary CTA -->
    <a 
      href="{{ cta_link }}"
      class="primary-cta"
      aria-label="{{ cta_text | escape }}"
    >
      <span class="cta-content">
        {{ cta_text }}
        <span class="cta-arrow" aria-hidden="true"></span>
      </span>
    </a>
    
    <!-- Footnote Subtitle -->
    <p class="hero-subtitle">
      {{ subtitle }}
    </p>
    
  </div>
</section>

<!-- ============================================================
     SECTION SCHEMA
     ============================================================ -->
{% schema %}
{
  "name": "The Gift Guide Hero",
  "tag": "section",
  "class": "gift-guide-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "🖼️ Background Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Banner Image",
      "info": "Recommended size: 1440px × 780px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (Fallback)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 15,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "📝 Header Settings"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header Background",
      "default": "#F5F5F5"
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Header Element Gap (px)",
      "min": 100,
      "max": 500,
      "step": 10,
      "default": 360,
      "unit": "px"
    },
    {
